{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bim-ai.local/schemas/sketch-understanding-ir.schema.json",
  "title": "Sketch Understanding IR",
  "description": "Machine-checkable visual brief for sketch-to-BIM project initiation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "projectType",
    "qualityTarget",
    "sourceInputs",
    "visualRead",
    "features",
    "requiredViews",
    "assumptions"
  ],
  "properties": {
    "schemaVersion": {
      "const": "sketch-understanding-ir.v0"
    },
    "projectType": {
      "type": "string",
      "minLength": 1
    },
    "qualityTarget": {
      "type": "string",
      "enum": ["massing_only", "concept_bim", "project_initiation_bim", "documentation_ready"]
    },
    "sourceInputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["images"],
      "properties": {
        "images": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "briefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "userInstruction": {
          "type": "string"
        }
      }
    },
    "visualRead": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primaryView", "dominantVolumes", "nonNegotiables"],
      "properties": {
        "primaryView": {
          "type": "string",
          "minLength": 1
        },
        "style": {
          "type": "string"
        },
        "dominantVolumes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "description", "priority"],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "priority": {
                "$ref": "#/$defs/priority"
              }
            }
          }
        },
        "nonNegotiables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbiddenOutcomes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "dimensions": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          { "type": "number" },
          { "type": "string" },
          { "type": "boolean" },
          { "type": "null" }
        ]
      },
      "properties": {
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "programme": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "level"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "level": {
            "type": "string",
            "minLength": 1
          },
          "programmeCode": {
            "type": "string",
            "minLength": 1
          },
          "targetAreaM2": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "requiredDoor": {
            "type": "boolean"
          }
        }
      }
    },
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "visualPriority", "mustRenderInViews"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "visualPriority": {
            "$ref": "#/$defs/priority"
          },
          "mustRenderInViews": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "capabilityNeeds": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "requiredViews": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "purpose"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": ["3d", "plan", "section", "elevation", "diagnostic"]
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "statement", "confidence"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "$ref": "#/$defs/confidence"
          },
          "validation": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"]
    },
    "confidence": {
      "type": "string",
      "enum": ["explicit", "high", "medium", "low", "estimated", "estimated_from_image", "unknown"]
    }
  }
}
