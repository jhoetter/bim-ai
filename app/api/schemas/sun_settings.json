{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SunSettings",
  "description": "SUN-V3-01: project-level sun position singleton.",
  "definitions": {
    "TimeOfDay": {
      "type": "object",
      "properties": {
        "hours": { "type": "integer", "minimum": 0, "maximum": 23 },
        "minutes": { "type": "integer", "minimum": 0, "maximum": 59 }
      },
      "required": ["hours", "minutes"],
      "additionalProperties": false
    },
    "AnimationRange": {
      "type": "object",
      "properties": {
        "startIso": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "endIso": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "intervalMinutes": { "type": "integer", "minimum": 1 }
      },
      "required": ["startIso", "endIso", "intervalMinutes"],
      "additionalProperties": false
    },
    "CreateSunSettingsRequest": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "const": "createSunSettings" },
        "latitudeDeg": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitudeDeg": { "type": "number", "minimum": -180, "maximum": 180 },
        "dateIso": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "timeOfDay": { "$ref": "#/definitions/TimeOfDay" },
        "daylightSavingStrategy": { "type": "string", "enum": ["auto", "on", "off"] }
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "UpdateSunSettingsRequest": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "const": "updateSunSettings" },
        "latitudeDeg": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitudeDeg": { "type": "number", "minimum": -180, "maximum": 180 },
        "dateIso": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "timeOfDay": { "$ref": "#/definitions/TimeOfDay" },
        "daylightSavingStrategy": { "type": "string", "enum": ["auto", "on", "off"] }
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "SunSettingsResponse": {
      "type": "object",
      "properties": {
        "kind": { "type": "string", "const": "sun_settings" },
        "id": { "type": "string" },
        "latitudeDeg": { "type": "number" },
        "longitudeDeg": { "type": "number" },
        "dateIso": { "type": "string" },
        "timeOfDay": { "$ref": "#/definitions/TimeOfDay" },
        "animationRange": { "$ref": "#/definitions/AnimationRange" },
        "daylightSavingStrategy": { "type": "string" }
      },
      "required": ["kind", "id", "latitudeDeg", "longitudeDeg", "dateIso", "timeOfDay"],
      "additionalProperties": false
    }
  }
}
